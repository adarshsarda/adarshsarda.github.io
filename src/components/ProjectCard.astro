---
interface ProjectCardData {
  title?: string;
  subtitle?: string;
  summary?: string;
  category?: string;
  status?: string;
  skills?: string[];
  domains?: string[];
}

interface Props {
  href: string;
  index: number;
  data: ProjectCardData;
}

const { href, index, data } = Astro.props;
---

<a class="project-card" href={href}>
  <div class="project-card-main">
    <div class="project-card-head">
      <span class="project-index">R-{String(index + 1).padStart(2, '0')}</span>
      <p class="entry-kicker">{data.category?.replaceAll('-', ' ') ?? 'research project'}</p>
    </div>
    <h2>{data.title}</h2>
    {data.subtitle && <p class="project-card-sub">{data.subtitle}</p>}
    {data.summary && <p class="project-card-summary">{data.summary}</p>}
    {data.skills && data.skills.length > 0 && (
      <ul class="chips">
        {data.skills.slice(0, 6).map((skill) => <li class="chip">{skill}</li>)}
      </ul>
    )}
  </div>
  <div class="project-card-rail">
    <div class="project-rail-item">
      <p class="rail-label">Status</p>
      <p class="rail-value">{data.status ?? 'documented'}</p>
    </div>
    {data.domains && data.domains.length > 0 && (
      <div class="project-rail-item">
        <p class="rail-label">Focus</p>
        <p class="rail-value">{data.domains.join(' · ')}</p>
      </div>
    )}
    <span class="project-card-cta">Open case file <span aria-hidden="true">→</span></span>
  </div>
</a>
