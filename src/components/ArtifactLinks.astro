---
interface Artifact {
  kind: string;
  label?: string;
  doi?: string;
  path?: string;
  url?: string;
}

interface Props {
  artifacts?: Artifact[];
  lang?: 'en' | 'de';
}

const { artifacts = [], lang = 'en' } = Astro.props;
const kindLabels: Record<string, Record<string, string>> = {
  en: {},
  de: {
    report: 'Bericht',
    code: 'Code',
    publication: 'Publikation',
    slides: 'Folien',
    manuscript: 'Manuskript',
    paper: 'Paper',
  },
};
---

{artifacts.length > 0 && (
  <div class="artifact-links">
    {artifacts.map((artifact) => {
      const href = artifact.url ?? artifact.path;
      if (!href) return null;
      const opensNewTab = href.startsWith('http') || href.endsWith('.pdf');
      return (
        <a
          href={href}
          target={opensNewTab ? '_blank' : undefined}
          rel={opensNewTab ? 'noopener noreferrer' : undefined}
        >
          <span>{kindLabels[lang][artifact.kind] ?? artifact.kind}</span>
          {artifact.label ?? artifact.doi ?? artifact.kind} <b aria-hidden="true">↗</b>
        </a>
      );
    })}
  </div>
)}
