---
interface Props {
  guideCount: number;
  talkCount: number;
  fieldHref: string;
  talkHref: string;
  fieldCountLabel: string;
  talkCountLabel: string;
  fieldDescription: string;
  talkDescription: string;
  fieldCta: string;
  talkCta: string;
  fieldTitle?: string;
  talkTitle?: string;
}

const {
  guideCount,
  talkCount,
  fieldHref,
  talkHref,
  fieldCountLabel,
  talkCountLabel,
  fieldDescription,
  talkDescription,
  fieldCta,
  talkCta,
  fieldTitle = 'Field Notes',
  talkTitle = 'Talk Notes',
} = Astro.props;
---

<div class="notes-hub">
  <a class="notes-hub-card notes-hub-card--field" href={fieldHref}>
    <div class="notes-hub-top">
      <span class="notes-hub-count">{guideCount} {fieldCountLabel}</span>
    </div>
    <h2>{fieldTitle}</h2>
    <p>{fieldDescription}</p>
    <span class="notes-hub-cta">{fieldCta} <span aria-hidden="true">→</span></span>
  </a>

  <a class="notes-hub-card notes-hub-card--talk" href={talkHref}>
    <div class="notes-hub-top">
      <span class="notes-hub-count">{talkCount} {talkCountLabel}</span>
    </div>
    <h2>{talkTitle}</h2>
    <p>{talkDescription}</p>
    <span class="notes-hub-cta">{talkCta} <span aria-hidden="true">→</span></span>
  </a>
</div>

<style>
  .notes-hub {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .notes-hub-card {
    display: flex;
    flex-direction: column;
    min-height: 320px;
    padding: 30px 32px 28px;
    color: var(--paper-raised);
    text-decoration: none;
    transition: transform 180ms ease;
  }

  .notes-hub-card--field {
    background: var(--signal);
  }

  .notes-hub-card--talk {
    background: var(--moss);
  }

  .notes-hub-card:hover {
    transform: translateY(-4px);
  }

  .notes-hub-top {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
  }

  .notes-hub-count {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .notes-hub-card h2 {
    margin: 28px 0 12px;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 3.2vw, 2.7rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 1.04;
  }

  .notes-hub-card > p {
    margin: 0;
    max-width: 38ch;
    font-size: 0.95rem;
    line-height: 1.55;
    opacity: 0.88;
  }

  .notes-hub-cta {
    margin-top: auto;
    padding-top: 26px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .notes-hub-card:hover .notes-hub-cta {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 720px) {
    .notes-hub {
      grid-template-columns: 1fr;
    }

    .notes-hub-card {
      min-height: 220px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .notes-hub-card {
      transition: none;
    }
  }
</style>
