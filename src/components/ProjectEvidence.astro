---
interface Condition {
  code: string;
  first: string;
  relation: string;
  second?: string;
  outcome: string;
  trigger: boolean;
}

interface Metric {
  name: string;
  value: string;
  denominator?: string;
  ci_95?: string;
}

interface Evidence {
  label: string;
  title: string;
  conditions: Condition[];
  metric_names: string[];
  credibility: {
    label: string;
    title: string;
    body: string;
  };
}

interface Props {
  evidence: Evidence;
  metrics?: Metric[];
}

const { evidence, metrics = [] } = Astro.props;
const selectedMetrics = evidence.metric_names
  .map((name) => metrics.find((metric) => metric.name === name))
  .filter((metric): metric is Metric => Boolean(metric));
---

<section class="case-evidence" aria-label={`${evidence.label} evidence summary`}>
  <div class="condition-panel">
    <div class="evidence-heading">
      <p class="profile-kicker">{evidence.label}</p>
      <h2>{evidence.title}</h2>
    </div>
    <div class="condition-grid">
      {evidence.conditions.map((condition) => (
        <div class:list={['condition-row', { trigger: condition.trigger }]}>
          <b>{condition.code}</b>
          <span>{condition.first}</span>
          <i>{condition.relation}</i>
          <span class:list={{ 'empty-cell': !condition.second }}>{condition.second ?? '—'}</span>
          <strong>{condition.outcome}</strong>
        </div>
      ))}
    </div>
  </div>

  {selectedMetrics.length > 0 && (
    <div class="metric-panel">
      <p class="profile-kicker">Verified results</p>
      <div class="metric-grid">
        {selectedMetrics.map((metric) => (
          <div class="metric-card">
            <strong>{metric.value}</strong>
            <h3>{metric.name}</h3>
            {metric.denominator && <p>{metric.denominator}</p>}
            {metric.ci_95 && <p>95% CI {metric.ci_95}</p>}
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="credibility-note">
    <p class="profile-kicker">{evidence.credibility.label}</p>
    <h2>{evidence.credibility.title}</h2>
    <p>{evidence.credibility.body}</p>
  </div>
</section>

<style>
  .case-evidence {
    margin: -20px 0 70px;
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(330px, 0.85fr);
    border: 1px solid var(--moss);
  }

  .condition-panel,
  .metric-panel,
  .credibility-note {
    padding: 30px;
  }

  .condition-panel {
    border-right: 1px solid var(--moss);
  }

  .evidence-heading h2,
  .credibility-note h2 {
    margin: 5px 0 24px;
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  .condition-grid {
    border-top: 1px solid var(--rule-dark);
  }

  .condition-row {
    padding: 9px 0;
    display: grid;
    grid-template-columns: 32px 1fr 44px 1fr 92px;
    gap: 8px;
    align-items: center;
    border-bottom: 1px solid var(--rule);
    font-family: var(--font-mono);
    font-size: 0.66rem;
  }

  .condition-row b {
    color: var(--signal-dark);
  }

  .condition-row span,
  .condition-row strong {
    padding: 6px 7px;
    border: 1px solid var(--rule);
    font-weight: 600;
  }

  .condition-row i {
    color: var(--ink-soft);
    font-style: normal;
    text-align: center;
  }

  .condition-row strong {
    text-align: center;
  }

  .condition-row.trigger span {
    background: color-mix(in srgb, var(--signal) 10%, transparent);
    border-color: color-mix(in srgb, var(--signal) 45%, var(--rule));
  }

  .condition-row.trigger strong {
    color: var(--paper-raised);
    background: var(--moss);
    border-color: var(--moss);
  }

  .condition-row .empty-cell {
    color: var(--ink-soft);
    background: transparent;
    text-align: center;
  }

  .metric-panel {
    background: color-mix(in srgb, var(--sky) 32%, transparent);
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }

  .metric-card {
    min-height: 145px;
    padding: 18px;
    background: var(--paper-raised);
  }

  .metric-card strong {
    display: block;
    color: var(--signal-dark);
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .metric-card h3 {
    margin: 7px 0 11px;
    font-size: 0.8rem;
    line-height: 1.3;
  }

  .metric-card p {
    margin: 2px 0 0;
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: 0.6rem;
  }

  .credibility-note {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 150px minmax(260px, 0.65fr) 1fr;
    gap: 28px;
    align-items: start;
    color: var(--paper-raised);
    background: var(--moss);
  }

  .credibility-note .profile-kicker {
    color: #c7d7cf;
  }

  .credibility-note h2,
  .credibility-note p {
    margin: 0;
  }

  .credibility-note > p:last-child {
    color: #dbe3de;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .case-evidence {
      grid-template-columns: 1fr;
    }

    .condition-panel {
      border-right: 0;
      border-bottom: 1px solid var(--moss);
    }

    .credibility-note {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .condition-panel,
    .metric-panel,
    .credibility-note {
      padding: 22px 18px;
    }

    .condition-row {
      grid-template-columns: 28px 1fr 38px 1fr;
    }

    .condition-row strong {
      grid-column: 2 / -1;
    }

    .metric-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
