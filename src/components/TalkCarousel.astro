---
import TalkCard from './TalkCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'talks'>[];
  hrefPrefix?: string;
  previousLabel?: string;
  nextLabel?: string;
  carouselLabel?: string;
  footerText?: string;
  indexHref: string;
  indexCta: string;
}

const {
  entries,
  hrefPrefix = '/talks',
  previousLabel = 'Show previous talk note',
  nextLabel = 'Show next talk note',
  carouselLabel = 'Talk Notes carousel',
  footerText = 'Use the arrows, swipe, or scroll horizontally.',
  indexHref,
  indexCta,
} = Astro.props;

const talkCount = entries.length;
---

<div class="talk-carousel-shell" data-talk-carousel>
  <button
    class="talk-carousel-arrow talk-carousel-arrow-prev"
    type="button"
    aria-label={previousLabel}
    aria-controls="home-talk-carousel"
    data-talk-prev
    disabled
  >
    <span aria-hidden="true">←</span>
  </button>

  <ol
    class="talk-carousel-track"
    id="home-talk-carousel"
    aria-label={carouselLabel}
    tabindex="0"
    data-talk-track
  >
    {entries.map((talk, index) => (
      <li class="talk-carousel-slide">
        <TalkCard entry={talk} index={index} hrefPrefix={hrefPrefix} />
      </li>
    ))}
  </ol>

  <button
    class="talk-carousel-arrow talk-carousel-arrow-next"
    type="button"
    aria-label={nextLabel}
    aria-controls="home-talk-carousel"
    data-talk-next
  >
    <span aria-hidden="true">→</span>
  </button>

  <footer class="talk-carousel-footer">
    <p class="talk-carousel-status" aria-live="polite">
      <span data-talk-position>01-02</span>
      <span aria-hidden="true"> / </span>
      <span>{talkCount.toString().padStart(2, '0')}</span>
    </p>
    <div>
      <p>{footerText}</p>
      <a class="text-link quiet" href={indexHref}>
        {indexCta} <span aria-hidden="true">→</span>
      </a>
    </div>
  </footer>
</div>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-talk-carousel]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  carousels.forEach((carousel) => {
    const track = carousel.querySelector<HTMLOListElement>('[data-talk-track]');
    const previous = carousel.querySelector<HTMLButtonElement>('[data-talk-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-talk-next]');
    const position = carousel.querySelector<HTMLElement>('[data-talk-position]');
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.talk-carousel-slide'));

    if (!track || !previous || !next || !position || slides.length === 0) return;

    const metrics = () => {
      const firstSlide = slides[0];
      const styles = getComputedStyle(track);
      const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;
      const step = firstSlide.getBoundingClientRect().width + gap;
      const visible = Math.max(1, Math.round((track.clientWidth + gap) / step));
      return { step, visible };
    };

    const update = () => {
      const { step, visible } = metrics();
      const first = Math.min(
        slides.length,
        Math.max(1, Math.round(track.scrollLeft / step) + 1),
      );
      const last = Math.min(slides.length, first + visible - 1);
      const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);

      previous.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= maxScroll - 2;
      position.textContent = first === last
        ? String(first).padStart(2, '0')
        : `${String(first).padStart(2, '0')}-${String(last).padStart(2, '0')}`;
    };

    const move = (direction: number) => {
      const { step } = metrics();
      track.scrollBy({
        left: direction * step,
        behavior: reduceMotion.matches ? 'auto' : 'smooth',
      });
    };

    previous.addEventListener('click', () => move(-1));
    next.addEventListener('click', () => move(1));
    track.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        move(-1);
      }
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        move(1);
      }
    });

    let frame = 0;
    track.addEventListener('scroll', () => {
      cancelAnimationFrame(frame);
      frame = requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  .talk-carousel-shell {
    position: relative;
    margin-top: 18px;
  }

  .talk-carousel-track {
    margin: 0;
    padding: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 18px) / 2);
    gap: 18px;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-behavior: smooth;
    scroll-snap-type: inline mandatory;
    scrollbar-width: none;
    list-style: none;
  }

  .talk-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .talk-carousel-track:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 5px;
  }

  .talk-carousel-slide {
    min-width: 0;
    display: grid;
    scroll-snap-align: start;
  }

  .talk-carousel-arrow {
    position: absolute;
    z-index: 3;
    top: 50%;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    color: var(--paper-raised);
    background: var(--signal-dark);
    border: 1px solid var(--paper-raised);
    border-radius: 50%;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--ink) 24%, transparent);
    font-family: var(--font-body);
    font-size: 1.4rem;
    cursor: pointer;
    transform: translateY(-50%);
    transition: background-color 160ms ease, transform 160ms ease, opacity 160ms ease;
  }

  .talk-carousel-arrow:hover:not(:disabled) {
    background: var(--signal);
    transform: translateY(-50%) scale(1.06);
  }

  .talk-carousel-arrow:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 4px;
  }

  .talk-carousel-arrow:disabled {
    opacity: 0.28;
    cursor: default;
  }

  .talk-carousel-arrow-prev {
    left: -24px;
  }

  .talk-carousel-arrow-next {
    right: -24px;
  }

  .talk-carousel-footer {
    padding-top: 18px;
    display: flex;
    justify-content: space-between;
    gap: 30px;
    align-items: flex-end;
  }

  .talk-carousel-footer > div {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
    gap: 14px 28px;
  }

  .talk-carousel-footer p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.78rem;
  }

  .talk-carousel-status {
    flex: none;
    color: var(--signal-dark) !important;
    font-family: var(--font-mono);
    font-size: 0.72rem !important;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  @media (max-width: 820px) {
    .talk-carousel-track {
      grid-auto-columns: 100%;
    }

    .talk-carousel-arrow-prev {
      left: -12px;
    }

    .talk-carousel-arrow-next {
      right: -12px;
    }
  }

  @media (max-width: 600px) {
    .talk-carousel-shell {
      padding-bottom: 62px;
    }

    .talk-carousel-arrow {
      top: auto;
      bottom: 0;
      transform: none;
    }

    .talk-carousel-arrow:hover:not(:disabled) {
      transform: scale(1.06);
    }

    .talk-carousel-arrow-prev {
      left: 0;
    }

    .talk-carousel-arrow-next {
      right: 0;
    }

    .talk-carousel-footer {
      padding-top: 14px;
      align-items: flex-start;
    }

    .talk-carousel-footer > div {
      justify-content: flex-end;
    }

    .talk-carousel-footer > div > p {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .talk-carousel-track {
      scroll-behavior: auto;
    }

    .talk-carousel-arrow {
      transition: none;
    }
  }
</style>
