---
interface Artifact {
  kind: string;
  label: string;
  path?: string;
  url?: string;
}

interface Props {
  paperUrl?: string;
  artifacts?: Artifact[];
  compact?: boolean;
  dark?: boolean;
  lang?: 'en' | 'de';
}

const { paperUrl, artifacts = [], compact = false, dark = false, lang = 'en' } = Astro.props;
const originalPaperLabel = lang === 'de' ? 'Originalpaper' : 'Original paper';
const resources = [
  ...(paperUrl ? [{ kind: 'paper', label: originalPaperLabel, href: paperUrl }] : []),
  ...artifacts.flatMap((artifact) => {
    const href = artifact.url ?? artifact.path;
    return href ? [{ kind: artifact.kind, label: artifact.label, href }] : [];
  }),
];
---

{resources.length > 0 && (
  <div class:list={['resource-links', { compact, dark }]}>
    {resources.map((resource) => {
      const opensNewTab = resource.href.startsWith('http') || resource.href.endsWith('.pdf');
      return (
        <a
          href={resource.href}
          target={opensNewTab ? '_blank' : undefined}
          rel={opensNewTab ? 'noopener noreferrer' : undefined}
        >
          <span>{resource.kind}</span>
          {resource.label}
          <b aria-hidden="true">↗</b>
        </a>
      );
    })}
  </div>
)}

<style>
  .resource-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .resource-links a {
    min-width: 220px;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2px 16px;
    color: var(--ink);
    background: color-mix(in srgb, var(--paper-raised) 70%, transparent);
    border: 1px solid var(--rule-dark);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-decoration: none;
  }

  .resource-links a:hover {
    color: var(--signal-dark);
    border-color: var(--signal);
  }

  .resource-links span {
    grid-column: 1 / -1;
    color: var(--signal-dark);
    font-size: 0.6rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .resource-links b {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 400;
  }

  .resource-links.compact {
    gap: 8px 14px;
  }

  .resource-links.compact a {
    min-width: 0;
    padding: 0 0 2px;
    display: inline-flex;
    gap: 7px;
    align-items: center;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--rule-dark);
    font-size: 0.65rem;
  }

  .resource-links.compact span {
    display: none;
  }

  .resource-links.dark a {
    color: #dbe3de;
    border-color: #91a299;
  }

  .resource-links.dark a:hover {
    color: var(--paper-raised);
    border-color: var(--paper-raised);
  }
</style>
