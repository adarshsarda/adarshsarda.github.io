---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  type?: 'website' | 'article';
  image?: string;
  structuredData?: Record<string, unknown>;
  lang?: 'en' | 'de';
  alternatePath?: string;
}

const {
  title,
  description,
  wide = false,
  type = 'website',
  image = '/images/portrait.jpeg',
  structuredData,
  lang = 'en',
  alternatePath,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const site = Astro.site ?? Astro.url.origin;
const canonical = new URL(path, site);
const socialImage = new URL(image, site);
const i18n = {
  en: {
    skip: 'Skip to main content',
    navLabel: 'Primary navigation',
    home: '',
    about: 'about/',
    projects: 'projects/',
    notes: 'notes/',
    publications: 'publications/',
    cv: 'cv/',
    labels: ['About', 'Projects', 'Notes', 'Publications', 'CV'],
  },
  de: {
    skip: 'Zum Hauptinhalt springen',
    navLabel: 'Hauptnavigation',
    home: 'de/',
    about: 'de/about/',
    projects: 'de/projects/',
    notes: 'de/notes/',
    publications: 'de/publications/',
    cv: 'de/cv/',
    labels: ['Über mich', 'Projekte', 'Notizen', 'Publikationen', 'Lebenslauf'],
  },
} as const;
const copy = i18n[lang];
const defaultAlternatePath = lang === 'de'
  ? path.replace(/^\/de(?=\/|$)/, '') || '/'
  : (path === '/' ? '/de/' : `/de${path}`);
const resolvedAlternatePath = alternatePath ?? defaultAlternatePath;
const enPath = lang === 'en' ? path : resolvedAlternatePath;
const dePath = lang === 'de' ? path : resolvedAlternatePath;
const langAlternates = [
  { lang: 'en', path: enPath },
  { lang: 'de', path: dePath },
];
const isActive = (targets: string[]) => targets.some((target) => path === target || path.startsWith(target));
const aboutActive = isActive(['/about/', '/de/about/']);
const projectsActive = isActive(['/projects/', '/de/projects/']);
const notesActive = isActive(['/notes/', '/guides/', '/talks/', '/de/notes/', '/de/guides/', '/de/talks/']);
const publicationsActive = isActive(['/publications/', '/de/publications/']);
const cvActive = isActive(['/cv/', '/de/cv/']);
const navItems = [
  { number: '01', label: copy.labels[0], href: copy.about, active: aboutActive },
  { number: '02', label: copy.labels[1], href: copy.projects, active: projectsActive },
  { number: '03', label: copy.labels[2], href: copy.notes, active: notesActive },
  { number: '04', label: copy.labels[3], href: copy.publications, active: publicationsActive },
  { number: '05', label: copy.labels[4], href: copy.cv, active: cvActive },
];
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${site}#person`,
      name: 'Adarsh Sarda',
      url: site.toString(),
      image: new URL('/images/portrait.jpeg', site).toString(),
      email: 'mailto:adarshsarda29@gmail.com',
      sameAs: [
        'https://www.linkedin.com/in/adarshsarda',
        'https://github.com/adarshsarda/',
      ],
      jobTitle: 'AI security researcher and engineer',
      homeLocation: {
        '@type': 'Place',
        name: 'Amberg, Germany',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${site}#website`,
      name: 'Adarsh Sarda',
      url: site.toString(),
      description: 'Research and field notes on AI security, LLM red teaming, and adversarial machine learning.',
      author: { '@id': `${site}#person` },
    },
    ...(structuredData ? [structuredData] : []),
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    {langAlternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={new URL(alternate.path, site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(enPath, site)} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Adarsh Sarda" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Portrait of Adarsh Sarda" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replaceAll('<', '\\u003c')} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{copy.skip}</a>
    <header class="site-header">
      <div class="bar">
        <a href={`${base}${copy.home}`} class="brand" aria-label="Adarsh Sarda, home">
          <span class="brand-mark" aria-hidden="true">AS</span>
        </a>
        <div class="header-links">
          <nav aria-label={copy.navLabel}>
            {navItems.map((item) => (
              <a href={`${base}${item.href}`} class={item.active ? 'active' : undefined} aria-current={item.active ? 'page' : undefined}>
                <span>{item.number}</span> {item.label}
              </a>
            ))}
          </nav>
          <nav class="language-switch" aria-label="Language switcher">
            <a href={new URL(enPath, site).pathname} class={lang === 'en' ? 'active' : undefined} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
            <span aria-hidden="true">·</span>
            <a href={new URL(dePath, site).pathname} class={lang === 'de' ? 'active' : undefined} aria-current={lang === 'de' ? 'true' : undefined}>DE</a>
          </nav>
        </div>
      </div>
    </header>

    <main id="main-content" class={wide ? 'container wide' : 'container'}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container wide">
        <p>© {year} Adarsh Sarda</p>
        <div class="footer-links">
          <a href="mailto:adarshsarda29@gmail.com">Email</a>
          <a href="https://www.linkedin.com/in/adarshsarda" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="https://github.com/adarshsarda/" target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
