---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a href={base} class="brand">Adarsh</a>
        <nav>
          <a href={`${base}projects/`}>Projects</a>
          <a href={`${base}guides/`}>Guides</a>
        </nav>
      </div>
    </header>

    <main class={wide ? 'container wide' : 'container'}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container wide">
        <p>© {year} Adarsh · built with Astro · deployed on GitHub Pages</p>
      </div>
    </footer>
  </body>
</html>
