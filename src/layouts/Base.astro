---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const projectsActive = path.includes('/projects');
const guidesActive = path.includes('/guides');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="bar">
        <a href={base} class="brand" aria-label="Adarsh Sarda, home">
          <span class="brand-mark" aria-hidden="true">AS</span>
          <span class="brand-name">Adarsh Sarda</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${base}projects/`} class={projectsActive ? 'active' : undefined} aria-current={projectsActive ? 'page' : undefined}>
            <span>01</span> Projects
          </a>
          <a href={`${base}guides/`} class={guidesActive ? 'active' : undefined} aria-current={guidesActive ? 'page' : undefined}>
            <span>02</span> Field notes
          </a>
        </nav>
      </div>
    </header>

    <main class={wide ? 'container wide' : 'container'}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container wide">
        <p>© {year} Adarsh Sarda</p>
        <p>AI security research · methods · field notes</p>
      </div>
    </footer>
  </body>
</html>
