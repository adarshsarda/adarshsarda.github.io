---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  type?: 'website' | 'article';
  image?: string;
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description,
  wide = false,
  type = 'website',
  image = '/images/portrait.jpeg',
  structuredData,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
const path = Astro.url.pathname;
const site = Astro.site ?? Astro.url.origin;
const canonical = new URL(path, site);
const socialImage = new URL(image, site);
const aboutActive = path.includes('/about');
const projectsActive = path.includes('/projects');
const guidesActive = path.includes('/guides');
const talksActive = path.includes('/talks');
const publicationsActive = path.includes('/publications');
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${site}#person`,
      name: 'Adarsh Sarda',
      url: site.toString(),
      image: new URL('/images/portrait.jpeg', site).toString(),
      email: 'mailto:adarshsarda29@gmail.com',
      sameAs: [
        'https://www.linkedin.com/in/adarshsarda',
        'https://github.com/adarshsarda/',
      ],
      jobTitle: 'AI security researcher and engineer',
      homeLocation: {
        '@type': 'Place',
        name: 'Amberg, Germany',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${site}#website`,
      name: 'Adarsh Sarda',
      url: site.toString(),
      description: 'Research and field notes on AI security, LLM red teaming, and adversarial machine learning.',
      author: { '@id': `${site}#person` },
    },
    ...(structuredData ? [structuredData] : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Adarsh Sarda" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Portrait of Adarsh Sarda" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={socialImage} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd).replaceAll('<', '\\u003c')} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <div class="bar">
        <a href={base} class="brand" aria-label="Adarsh Sarda, home">
          <span class="brand-mark" aria-hidden="true">AS</span>
          <span class="brand-name">Adarsh Sarda</span>
        </a>
        <nav aria-label="Primary navigation">
          <a href={`${base}about/`} class={aboutActive ? 'active' : undefined} aria-current={aboutActive ? 'page' : undefined}>
            <span>01</span> About
          </a>
          <a href={`${base}projects/`} class={projectsActive ? 'active' : undefined} aria-current={projectsActive ? 'page' : undefined}>
            <span>02</span> Projects
          </a>
          <a href={`${base}guides/`} class={guidesActive ? 'active' : undefined} aria-current={guidesActive ? 'page' : undefined}>
            <span>03</span> Field Notes
          </a>
          <a href={`${base}talks/`} class={talksActive ? 'active' : undefined} aria-current={talksActive ? 'page' : undefined}>
            <span>04</span> Talks
          </a>
          <a href={`${base}publications/`} class={publicationsActive ? 'active' : undefined} aria-current={publicationsActive ? 'page' : undefined}>
            <span>05</span> Publications
          </a>
        </nav>
      </div>
    </header>

    <main id="main-content" class={wide ? 'container wide' : 'container'}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container wide">
        <p>© {year} Adarsh Sarda</p>
        <div class="footer-links">
          <a href="mailto:adarshsarda29@gmail.com">Email</a>
          <a href="https://www.linkedin.com/in/adarshsarda" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="https://github.com/adarshsarda/" target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
