---
import Base from '../../layouts/Base.astro';
import NoteCard from '../../components/NoteCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import TalkCarousel from '../../components/TalkCarousel.astro';
import { isPublishable } from '../../lib/contentVisibility';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const projectEntries = await getCollection('projects');
const guideEntries = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);
const talkEntries = (await getCollection('talks')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || b.data.last_updated.getTime() - a.data.last_updated.getTime(),
);

const projects = projectEntries
  .filter((entry) => entry.data.type === 'project' && isPublishable(entry))
  .map((entry) => ({ key: entry.data.slug, data: entry.data }))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projectCount = projects.length;
const guideCount = guideEntries.length;
const talkCount = talkEntries.length;
---

<Base
  title="Adarsh Sarda | KI-Sicherheitsforscher"
  description="Forschung und Notizen zu KI-Sicherheit, LLM Red Teaming und adversarial Machine Learning."
  lang="de"
  wide
>
  <section class="home-hero">
    <div class="hero-main">
      <p class="hero-name">Adarsh Sarda</p>
      <p class="eyebrow"><span>Forschung & Notizen</span> / KI-Sicherheit</p>
      <h1>Ich baue und prüfe <em>KI-Systeme.</em></h1>
      <p class="hero-deck">
        Ich arbeite an adversarial Machine Learning, LLM Red Teaming und
        experimenteller Sicherheitsforschung. Die technischen Fallstudien bleiben
        dort auf Englisch, wo Präzision und belegbare Claims wichtig sind.
      </p>
      <div class="hero-actions">
        <a class="text-link" href={`${base}de/projects/`}>Forschung lesen <span aria-hidden="true">↗</span></a>
        <a class="text-link quiet" href={`${base}de/about/`}>Über meine Arbeit <span aria-hidden="true">→</span></a>
        <a class="text-link quiet" href={`${base}de/cv/`}>
          Lebenslauf <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <figure class="hero-portrait">
      <div class="portrait-frame">
        <img
          src={`${base}images/portrait.jpeg`}
          alt="Porträt im Freien neben einem Fluss"
          width="900"
          height="1600"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="portrait-note">
        <p class="note-label">Aktuelle Frage / 2026</p>
        <p>Kann ein Multi-Turn-Modell eine versteckte Regel lernen, die auf der <strong>Reihenfolge von Bedeutungen</strong> statt auf einem Keyword basiert?</p>
      </div>
    </figure>
  </section>

  <section class="home-section principles-section">
    <header class="section-heading">
      <p><span>01</span> Forschungsprinzipien</p>
      <p>Wie ich Evidenz bewerte</p>
    </header>
    <div class="principle-grid">
      <div>
        <span>01</span>
        <h2>Statistisch messen.</h2>
        <p>KI-Fehler sind probabilistisch. Ich berichte Raten, Stichproben, Kontrollen und Unsicherheit.</p>
      </div>
      <div>
        <span>02</span>
        <h2>Fehlversuche dokumentieren.</h2>
        <p>Ein verworfener Shortcut erklärt oft mehr über das System als ein polierter Endwert.</p>
      </div>
      <div>
        <span>03</span>
        <h2>Demos von Evidenz trennen.</h2>
        <p>Installation, Generalisierung, Utility und reales Risiko sind unterschiedliche Aussagen.</p>
      </div>
      <div>
        <span>04</span>
        <h2>Perfekte Ergebnisse prüfen.</h2>
        <p>Perfekte Scores brauchen stärkere Audits, nicht stärkere Adjektive.</p>
      </div>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="home-section research-section">
      <header class="section-heading">
        <p><span>02</span> Ausgewählte Forschung</p>
        <p>{projectCount.toString().padStart(2, '0')} {projectCount === 1 ? 'Fallstudie' : 'Fallstudien'}</p>
      </header>
      <div class="project-card-list">
        {projects.map((project, index) => (
          <ProjectCard
            href={`${base}de/projects/${project.key}/`}
            index={index}
            data={project.data}
          />
        ))}
      </div>
    </section>
  )}

  {guideEntries.length > 0 && (
    <section class="home-section notes-section">
      <header class="section-heading">
        <p><span>03</span> Field Notes</p>
        <p>{guideCount.toString().padStart(2, '0')} {guideCount === 1 ? 'Guide' : 'Guides'}</p>
      </header>
      <div class="note-card-list">
        {guideEntries.map((guide, index) => (
          <NoteCard
            href={`${base}de/guides/${guide.id}/`}
            index={index}
            prefix="N"
            kicker="Practitioner field note"
            title={guide.data.title}
            description={guide.data.description}
            tags={guide.data.tags}
            cta="Notiz lesen"
          />
        ))}
      </div>
    </section>
  )}

  {talkEntries.length > 0 && (
    <section class="home-section talks-section">
      <header class="section-heading">
        <p><span>04</span> Talk Notes</p>
        <p>{talkCount.toString().padStart(2, '0')} {talkCount === 1 ? 'Präsentation' : 'Präsentationen'}</p>
      </header>

      <TalkCarousel
        entries={talkEntries}
        hrefPrefix="/de/talks"
        previousLabel="Vorherige Talk Note anzeigen"
        nextLabel="Nächste Talk Note anzeigen"
        carouselLabel="Talk Notes Karussell"
        footerText="Nutze die Pfeile, Swipe oder horizontales Scrollen."
        indexHref={`${base}de/talks/`}
        indexCta="Vollständigen Talk-Index öffnen"
      />
    </section>
  )}

  <section class="home-section contact-section">
    <div>
      <p class="profile-kicker">Kontakt</p>
      <h2>Interessiert an KI-Sicherheit, LLM-Evaluation oder angewandtem Machine Learning? Sprechen wir.</h2>
      <p>Ich bin in Amberg, Deutschland, und für Werkstudentenrollen mit 20 Stunden pro Woche verfügbar — vor Ort in der Region oder remote.</p>
    </div>
    <div class="contact-actions">
      <a class="text-link" href="mailto:adarshsarda29@gmail.com">Email <span aria-hidden="true">→</span></a>
      <a class="text-link quiet" href="https://www.linkedin.com/in/adarshsarda" target="_blank" rel="noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
      <a class="text-link quiet" href="https://github.com/adarshsarda/" target="_blank" rel="noreferrer">GitHub <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</Base>
