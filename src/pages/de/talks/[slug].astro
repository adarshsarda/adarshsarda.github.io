---
import Base from '../../../layouts/Base.astro';
import InternalLinkList from '../../../components/InternalLinkList.astro';
import ResourceLinks from '../../../components/ResourceLinks.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const talks = await getCollection('talksDe');
  return talks.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'talksDe'> };
const { Content, headings } = await render(entry);
const data = entry.data;
const detailedHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const toc = [
  { depth: 2, slug: 'one-line-takeaway', text: 'Takeaway in einem Satz' },
  { depth: 2, slug: 'why-this-talk-matters', text: 'Warum diese Arbeit wichtig ist' },
  { depth: 2, slug: 'core-ideas', text: 'Kernideen' },
  { depth: 2, slug: 'threat-model-security-angle', text: 'Threat Model / Security-Perspektive' },
  { depth: 2, slug: 'what-i-learned', text: 'Was ich gelernt habe' },
  { depth: 2, slug: 'connections-to-my-field-notes', text: 'Verbindungen zu meinen Feldnotizen' },
  { depth: 2, slug: 'related-resources', text: 'Ressourcen' },
  { depth: 2, slug: 'open-questions', text: 'Offene Fragen' },
  { depth: 2, slug: 'detailed-notes', text: 'Detaillierte Notizen' },
  ...detailedHeadings,
];
const dateFmt = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
const deConnections = data.connections.map((link) => ({
  ...link,
  href: link.href.startsWith('/') ? `/de${link.href}` : link.href,
}));
const formatLabels: Record<string, string> = {
  'Paper presentation': 'Paper-Präsentation',
  'Paper explainer': 'Paper-Erklärung',
  'Original research talk': 'Originalforschungs-Talk',
  Workshop: 'Workshop',
};
const difficultyLabels: Record<string, string> = {
  Beginner: 'Einsteiger',
  Intermediate: 'Mittel',
  Advanced: 'Fortgeschritten',
};
const trackLabels: Record<string, string> = {
  Backdoors: 'Backdoors',
  'Agent security': 'Agentensicherheit',
  'RAG and prompt injection': 'RAG und Prompt Injection',
  'AI supply chain': 'KI-Supply-Chain',
};
const trackLabel = data.track ? (trackLabels[data.track] ?? data.track) : undefined;
const formatLabel = formatLabels[data.format] ?? data.format;
const difficultyLabel = difficultyLabels[data.difficulty] ?? data.difficulty;
---

<Base
  title={`${data.title} | Talk-Notiz`}
  description={data.description}
  type="article"
  lang="de"
  structuredData={{
    '@type': 'PresentationDigitalDocument',
    '@id': `${Astro.url}#talk`,
    name: data.title,
    description: data.description,
    url: Astro.url.toString(),
    dateModified: data.last_updated.toISOString(),
    creator: { '@id': `${Astro.site ?? Astro.url.origin}#person` },
    isBasedOn: data.paper_url,
    keywords: data.tags?.join(', '),
  }}
  wide
>
  <p class="crumb"><a href={`${base}de/talks/`}>Notizen / Talk-Notizen</a></p>
  <header class="article-head">
    <div class="article-label">
      <span>{trackLabel ? `${trackLabel} / ` : ''}{formatLabel} / T-{String(data.order ?? 1).padStart(2, '0')}</span>
      <span>{difficultyLabel} / {data.year}</span>
    </div>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.description}</p>

    <dl class="meta-table">
      <dt>Sprecher</dt><dd>{data.speaker}</dd>
      <dt>Quelle</dt><dd>{data.source}</dd>
      <dt>Kontext</dt><dd>{data.event}</dd>
      <dt>Typ</dt><dd>{formatLabel}</dd>
      <dt>Schwierigkeit</dt><dd>{difficultyLabel}</dd>
      <dt>Aktualisiert</dt>
      <dd><time datetime={data.last_updated.toISOString()}>{dateFmt.format(data.last_updated)}</time></dd>
      {data.paper_title && (<><dt>Paper</dt><dd>{data.paper_title}</dd></>)}
      {data.paper_authors && (<><dt>Autorinnen/Autoren</dt><dd>{data.paper_authors.join(', ')}</dd></>)}
      {data.paper_venue && (<><dt>Venue</dt><dd>{data.paper_venue}</dd></>)}
    </dl>

    {data.format === 'Paper presentation' ? (
      <div class="talk-scope">
        <strong>Einordnung:</strong> Das ist meine Erklärung und Präsentation eines Papers
        eines anderen Forschungsteams, nicht meine eigene Originalforschung.
      </div>
    ) : (
      <div class="talk-scope">
        <strong>Einordnung:</strong> Das ist eine unabhängige Paper-Erklärung auf Basis
        der veröffentlichten Arbeit der Autorinnen und Autoren. Es ist nicht meine eigene
        Originalforschung und impliziert keinen gehaltenen Vortrag.
      </div>
    )}

    {data.tags && data.tags.length > 0 && (
      <ul class="chips article-tags">
        {data.tags.map((tag) => <li class="chip">{tag}</li>)}
      </ul>
    )}

  </header>

  <div class="with-toc">
    <article class="prose talk-note">
      <section id="one-line-takeaway">
        <h2>Takeaway in einem Satz</h2>
        <p class="takeaway">{data.takeaway}</p>
      </section>

      <section id="why-this-talk-matters">
        <h2>Warum diese Arbeit wichtig ist</h2>
        <p>{data.why_matters}</p>
      </section>

      <section id="core-ideas">
        <h2>Kernideen</h2>
        <ul>
          {data.core_ideas.map((idea) => <li>{idea}</li>)}
        </ul>
      </section>

      <section id="threat-model-security-angle">
        <h2>Threat Model / Security-Perspektive</h2>
        <dl class="threat-model">
          <dt>System</dt><dd>{data.threat_model.system}</dd>
          <dt>Angreifer</dt><dd>{data.threat_model.attacker}</dd>
          <dt>Benötigte Fähigkeit</dt><dd>{data.threat_model.capability}</dd>
          <dt>Fehlermodus</dt><dd>{data.threat_model.failure}</dd>
          <dt>Deployment-Relevanz</dt><dd>{data.threat_model.deployment}</dd>
        </dl>
      </section>

      <section id="what-i-learned">
        <h2>Was ich gelernt habe</h2>
        <p>{data.what_i_learned}</p>
      </section>

      <section id="connections-to-my-field-notes">
        <h2>Verbindungen zu meinen Feldnotizen</h2>
        <InternalLinkList links={deConnections} />
      </section>

      <section id="related-resources">
        <h2>Ressourcen</h2>
        <ResourceLinks paperUrl={data.paper_url} artifacts={data.artifacts} lang="de" />
      </section>

      <section id="open-questions">
        <h2>Offene Fragen</h2>
        <ul>
          {data.open_questions.map((question) => <li>{question}</li>)}
        </ul>
      </section>

      <section id="detailed-notes">
        <h2>Detaillierte Notizen</h2>
        <Content />
      </section>
    </article>

    {toc.length > 0 && (
      <aside class="toc" aria-label="Auf dieser Seite">
        <p class="toc-label">Auf dieser Seite</p>
        <ul>
          {toc.map((heading) => (
            <li class={`depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Base>

<style>
  .talk-scope {
    max-width: 820px;
    margin-top: 30px;
    padding: 14px 18px;
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--sky) 45%, transparent);
    border-left: 3px solid var(--signal);
    font-size: 0.9rem;
  }

  .talk-note > section {
    scroll-margin-top: 24px;
  }

  .takeaway {
    padding: 20px 22px;
    color: var(--paper-raised);
    background: var(--moss);
    border-left: 4px solid var(--signal);
    font-family: var(--font-display);
    font-size: 1.22rem;
    line-height: 1.5;
  }

  .threat-model {
    margin: 0;
    display: grid;
    grid-template-columns: 150px 1fr;
    border-top: 1px solid var(--rule-dark);
  }

  .threat-model dt,
  .threat-model dd {
    margin: 0;
    padding: 11px 0;
    border-bottom: 1px solid var(--rule);
  }

  .threat-model dt {
    color: var(--signal-dark);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .threat-model dd {
    font-family: var(--font-body);
    font-size: 0.9rem;
  }

  @media (max-width: 680px) {
    .threat-model {
      grid-template-columns: 1fr;
    }

    .threat-model dt {
      padding-bottom: 0;
      border-bottom: 0;
    }
  }
</style>
