---
import Base from '../../../layouts/Base.astro';
import TalkCard from '../../../components/TalkCard.astro';
import { getCollection } from 'astro:content';

const talks = (await getCollection('talks')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || b.data.last_updated.getTime() - a.data.last_updated.getTime(),
);
---

<Base
  title="Talk Notes | Adarsh Sarda"
  description="Strukturierte Lernnotizen aus Talks und Papers zu KI-Sicherheit, Red Teaming, Backdoors, RAG, Agents und Modell-Evaluation."
  lang="de"
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Notizen</span> / Connected learning artifacts</p>
    <h1>Talk Notes</h1>
    <p>
      Talks und Papers, gemappt auf Threat Models, defensive Lessons, persönliche
      Takeaways und Verbindungen zu meinen AI-Security Field Notes.
    </p>
  </div>

  <div class="talk-card-grid">
    {talks.map((talk, index) => <TalkCard entry={talk} index={index} hrefPrefix="/de/talks" />)}
  </div>
</Base>

<style>
  .talk-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 820px) {
    .talk-card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
