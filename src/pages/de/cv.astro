---
import Base from '../../layouts/Base.astro';
import '../../styles/cv.css';

const base = import.meta.env.BASE_URL;
const cvVersion = '20260619';
---

<Base
  title="Lebenslauf | Adarsh Sarda"
  description="Deutscher Lebenslauf von Adarsh Sarda, KI-Sicherheitsforscher und M.Sc.-Student Artificial Intelligence."
  lang="de"
>
  <div class="page-head cv-head">
    <p class="eyebrow"><span>Profil 05</span> / Lebenslauf</p>
    <h1>Lebenslauf</h1>
    <p>
      Der deutsche Lebenslauf ist für Bewerbungen auf Deutsch formatiert. Du
      kannst das Dokument hier ansehen, öffnen oder als PDF herunterladen.
    </p>
  </div>

  <div class="cv-grid cv-grid-single">
    <section class="cv-card-copy cv-card-copy-de" lang="de" aria-labelledby="german-cv-title">
      <div>
        <p class="cv-index">CV-01 / DE</p>
        <h2 id="german-cv-title">Deutscher Lebenslauf</h2>
        <p>KI-Sicherheit, Berufserfahrung, Bildungsweg und ausgewählte Forschungsarbeit.</p>
      </div>
      <div class="cv-actions">
        <a
          class="text-link"
          href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf?v=${cvVersion}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          PDF öffnen <span aria-hidden="true">↗</span>
        </a>
        <a
          class="text-link quiet"
          href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf?v=${cvVersion}`}
          download
        >
          Herunterladen <span aria-hidden="true">↓</span>
        </a>
        <a class="text-link quiet" href={`${base}cv/`}>
          Englischer CV <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <a
      class="cv-preview cv-preview-de"
      href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf?v=${cvVersion}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Deutschen Lebenslauf als PDF öffnen"
    >
      <img
        src={`${base}images/cv/german-preview.png`}
        alt="Vorschau des deutschen Lebenslaufs von Adarsh Sarda"
        width="982"
        height="1389"
        loading="eager"
      />
    </a>
  </div>
</Base>
