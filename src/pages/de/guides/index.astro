---
import Base from '../../../layouts/Base.astro';
import NoteCard from '../../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guides = (await getCollection('guidesDe')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);
---

<Base
  title="Feldnotizen | Adarsh Sarda"
  description="Praktische Feldnotizen zu KI-Sicherheit und Red Teaming."
  lang="de"
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Notizen</span> / Methoden und Checklisten</p>
    <h1>Feldnotizen</h1>
    <p>
      Längere Methodik- und Praxisnotizen zum Bewerten, Brechen und
      Härten von KI-Systemen.
    </p>
  </div>

  <div class="note-card-list">
    {guides.map((guide, index) => (
      <NoteCard
        href={`${base}de/guides/${guide.id}/`}
        index={index}
        prefix="N"
        kicker="Praxisnotiz"
        title={guide.data.title}
        description={guide.data.description}
        tags={guide.data.tags}
        cta="Notiz lesen"
      />
    ))}
  </div>
</Base>
