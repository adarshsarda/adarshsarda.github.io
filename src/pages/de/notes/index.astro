---
import Base from '../../../layouts/Base.astro';
import NotesHub from '../../../components/NotesHub.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guideCount = (await getCollection('guidesDe')).length;
const talkCount = (await getCollection('talksDe')).length;
---

<Base
  title="Notizen | Adarsh Sarda"
  description="Feldnotizen und Talk-Notizen zu KI-Sicherheit, LLM Red Teaming und adversarial Machine Learning."
  lang="de"
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Index 03</span> / Schreiben</p>
    <h1>Notizen</h1>
    <p>
      Zwei Textarten: längere Feldnotizen zu Methodik und strukturierte
      Talk-Notizen aus wissenschaftlichen Arbeiten und Vorträgen.
    </p>
  </div>

  <NotesHub
    guideCount={guideCount}
    talkCount={talkCount}
    fieldHref={`${base}de/guides/`}
    talkHref={`${base}de/talks/`}
    fieldTitle="Feldnotizen"
    talkTitle="Talk-Notizen"
    fieldCountLabel={guideCount === 1 ? 'Notiz' : 'Notizen'}
    talkCountLabel={talkCount === 1 ? 'Notiz' : 'Notizen'}
    fieldDescription="Längere Methodik- und Praxisnotizen zum Bewerten, Brechen und Härten von KI-Systemen."
    talkDescription="Vorträge und Papers, eingeordnet nach Threat Models, defensiven Erkenntnissen und persönlichen Takeaways."
    fieldCta="Feldnotizen öffnen"
    talkCta="Talk-Notizen öffnen"
  />
</Base>
