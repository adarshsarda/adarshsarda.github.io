---
import Base from '../layouts/Base.astro';
import '../styles/profile.css';
---

<Base
  title="Publications | Adarsh Sarda"
  description="Published academic work by Adarsh Sarda."
  structuredData={{
    '@type': 'ScholarlyArticle',
    '@id': 'https://doi.org/10.1007/978-981-19-5191-6_2',
    headline: 'Improving Mental Health Through Multimodal Emotion Detection from Speech and Text Data Using Long-Short Term Memory',
    datePublished: '2023-04-25',
    author: [
      { '@type': 'Person', name: 'D. Bhagat' },
      { '@type': 'Person', name: 'A. Ray' },
      { '@id': `${Astro.site ?? Astro.url.origin}#person` },
      { '@type': 'Person', name: 'N. Dutta Roy' },
      { '@type': 'Person', name: 'M. Mahmud' },
      { '@type': 'Person', name: 'D. De' },
    ],
    isPartOf: {
      '@type': 'PublicationVolume',
      name: 'Frontiers of ICT in Healthcare',
      volumeNumber: '519',
    },
    sameAs: 'https://doi.org/10.1007/978-981-19-5191-6_2',
  }}
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Index 05</span> / Academic work</p>
    <h1>Publications</h1>
    <p>Peer-reviewed work and the project context behind it.</p>
  </div>

  <article class="publication-entry">
    <div class="publication-number">P-01</div>
    <div class="publication-main">
      <p class="publication-type">Springer book chapter / 2023</p>
      <h2>Improving Mental Health Through Multimodal Emotion Detection from Speech and Text Data Using Long-Short Term Memory</h2>
      <p class="publication-authors">
        D. Bhagat, A. Ray, <strong>A. Sarda</strong>, N. Dutta Roy, M. Mahmud, and D. De
      </p>
      <p>
        Published in <em>Frontiers of ICT in Healthcare</em>, Lecture Notes in Networks
        and Systems, volume 519, pages 13-23. First published online April 25, 2023.
      </p>
      <p>
        The work presents a multimodal emotion-recognition prototype using speech and text,
        an LSTM-based classifier, RAVDESS and FastText resources, a voice-interactive
        workflow, and Twilio-based alerting. The bachelor thesis reports approximately
        86% model accuracy.
      </p>
      <div class="publication-links">
        <a class="text-link" href="https://doi.org/10.1007/978-981-19-5191-6_2" target="_blank" rel="noreferrer">
          Springer / DOI <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
    <aside class="publication-meta">
      <p><span>DOI</span>10.1007/978-981-19-5191-6_2</p>
      <p><span>Venue</span>Frontiers of ICT in Healthcare</p>
      <p><span>Series</span>LNNS 519</p>
      <p><span>Contribution</span>Co-author and bachelor project developer</p>
    </aside>
  </article>
</Base>
