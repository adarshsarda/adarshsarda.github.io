---
import Base from '../../layouts/Base.astro';
import NotesHub from '../../components/NotesHub.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guideCount = (await getCollection('guides')).length;
const talkCount = (await getCollection('talks')).length;
---

<Base
  title="Notes | Adarsh Sarda"
  description="Field notes and talk notes on AI security, LLM red teaming, and adversarial machine learning."
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Index 03</span> / Writing</p>
    <h1>Notes</h1>
    <p>Two kinds of write-up: long-form field notes on methodology, and structured talk notes from papers and presentations.</p>
  </div>

  <NotesHub
    guideCount={guideCount}
    talkCount={talkCount}
    fieldHref={`${base}guides/`}
    talkHref={`${base}talks/`}
    fieldCountLabel={guideCount === 1 ? 'note' : 'notes'}
    talkCountLabel={talkCount === 1 ? 'note' : 'notes'}
    fieldDescription="Long-form methodology and practitioner notes for assessing, breaking, and hardening AI systems."
    talkDescription="Talks and papers mapped into threat models, defensive lessons, and personal takeaways."
    fieldCta="Open Field Notes"
    talkCta="Open Talk Notes"
  />
</Base>
