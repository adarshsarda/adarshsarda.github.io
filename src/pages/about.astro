---
import Base from '../layouts/Base.astro';
import '../styles/profile.css';

const base = import.meta.env.BASE_URL;
---

<Base
  title="About | Adarsh Sarda"
  description="Research profile, experience, and technical focus of Adarsh Sarda."
  wide
>
  <div class="page-head profile-head">
    <p class="eyebrow"><span>Profile 01</span> / Research and experience</p>
    <h1>About</h1>
    <p>
      I work on AI systems from two directions: building them as an engineer and testing
      where their assumptions fail as a security researcher.
    </p>
  </div>

  <div class="profile-layout">
    <article class="profile-story">
      <section class="profile-card">
        <p class="profile-kicker">Current focus</p>
        <h2>AI security with an experimental mindset.</h2>
        <p>
          I am completing an M.Sc. in Artificial Intelligence for Industrial Applications
          at OTH Amberg-Weiden, with a focus on AI Security & Privacy. My current work covers
          semantic LLM backdoors, adversarial evaluation, deepfake-detector security, and
          the credibility of model-evaluation pipelines.
        </p>
        <p>
          I care about the gap between a convincing demonstration and defensible evidence.
          That means designing controls, measuring probabilistic behaviour, reporting failed
          iterations, and keeping limitations close to the result.
        </p>
      </section>

      <section class="profile-card profile-card--edu">
        <p class="profile-kicker">Education</p>
        <div class="timeline-list">
          <div class="timeline-entry">
            <p class="timeline-date">03/2025 - present</p>
            <div>
              <h3>M.Sc. Artificial Intelligence for Industrial Applications</h3>
              <p>OTH Amberg-Weiden, Bavaria</p>
              <p>Focus: AI Security & Privacy, machine learning, NLP, computer vision, and secure AI system design.</p>
            </div>
          </div>
          <div class="timeline-entry">
            <p class="timeline-date">08/2019 - 06/2023</p>
            <div>
              <h3>B.Tech Information Technology</h3>
              <p>Institute of Engineering and Management, Kolkata</p>
              <p>CGPA 8.6/10. Final-year work led to a co-authored Springer publication on multimodal emotion detection.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="profile-card profile-card--work">
        <p class="profile-kicker">Professional background</p>
        <h2>Technical research translated into decisions.</h2>
        <p>
          From January 2023 to October 2024, I worked as an AI Research Analyst at GreyB
          Research Pte. My work combined patent analytics, technology intelligence, and
          technical communication for international clients.
        </p>
        <ul class="profile-list">
          <li>Built an ML-based system for automated patent technology classification.</li>
          <li>Conducted infringement and prior-art analysis across AI/ML, blockchain, 3GPP, and IETF technologies.</li>
          <li>Mapped patent claims against technical implementations and product features.</li>
          <li>Produced technology landscapes and decision briefs for legal, strategy, and R&D stakeholders.</li>
        </ul>
      </section>
    </article>

    <aside class="profile-facts">
      <div class="fact-block">
        <p class="fact-label">Based in</p>
        <p>Amberg, Germany</p>
      </div>
      <div class="fact-block">
        <p class="fact-label">Availability</p>
        <p>Werkstudent, 20 hrs/week<br />Immediate start<br />Amberg, Regensburg, Nuremberg<br />and nearby, or remote</p>
      </div>
      <div class="fact-block">
        <p class="fact-label">Research</p>
        <p>LLM security<br />Adversarial ML<br />Deepfake security<br />AI evaluation</p>
      </div>
      <div class="fact-block">
        <p class="fact-label">Technical</p>
        <p>Python<br />PyTorch<br />Scikit-learn<br />NLP and LLMs<br />Computer vision</p>
      </div>
      <div class="fact-block">
        <p class="fact-label">Languages</p>
        <p>English C1<br />German B1<br />Hindi, native</p>
      </div>
      <div class="fact-block">
        <p class="fact-label">CV</p>
        <p>
          <a href={`${base}cv/`}>English CV<br />Deutscher Lebenslauf</a>
        </p>
      </div>
      <div class="fact-block">
        <p class="fact-label">Contact</p>
        <p>
          <a href="mailto:adarshsarda29@gmail.com">Email</a><br />
          <a href="https://www.linkedin.com/in/adarshsarda" target="_blank" rel="noreferrer">LinkedIn</a><br />
          <a href="https://github.com/adarshsarda/" target="_blank" rel="noreferrer">GitHub</a>
        </p>
      </div>
    </aside>
  </div>

  <section class="collaboration-strip">
    <p class="profile-kicker">Open to</p>
    <h2>Werkstudent roles and research collaborations in AI security, LLM evaluation, and applied machine learning.</h2>
    <a class="text-link" href="mailto:adarshsarda29@gmail.com">Start a conversation <span aria-hidden="true">→</span></a>
  </section>
</Base>
