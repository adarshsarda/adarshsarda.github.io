---
import Base from '../../layouts/Base.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const methods = (await getCollection('methods')).sort((a, b) =>
  (a.data.title ?? a.id).localeCompare(b.data.title ?? b.id),
);
---

<Base title="Methods | Adarsh Sarda" wide>
  <div class="page-head">
    <p class="eyebrow"><span>Index</span> / Methods</p>
    <h1>Methods</h1>
  </div>

  <div class="note-card-list">
    {methods.map((method, index) => (
      <NoteCard
        href={`${base}methods/${method.data.slug ?? method.id}/`}
        index={index}
        prefix="M"
        kicker="Method"
        title={method.data.title ?? method.id}
        tags={method.data.tags}
        cta="Read the method"
      />
    ))}
  </div>
</Base>
