---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const all = await getCollection('projects');

// Group the files by their project directory (the first id segment), then use
// the `type: project` overview file as the card. The detail files (method /
// results / reflection) count toward the section total but don't get a card.
const groups = new Map<string, typeof all>();
for (const entry of all) {
  const key = entry.id.split('/')[0];
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(entry);
}

const projects = [...groups.entries()]
  .flatMap(([key, entries]) => {
    const lead = entries.find((entry) => entry.data.type === 'project');
    return lead && lead.data.type === 'project'
      ? [{ key, data: lead.data, sections: entries.length }]
      : [];
  })
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Projects | Adarsh Sarda" description="Research projects and technical case files." wide>
  <div class="page-head">
    <p class="eyebrow"><span>Index 02</span> / Research archive</p>
    <h1>Case files</h1>
    <p>Original research on AI security and adversarial machine learning, including the methods that failed and the caveats that survived.</p>
  </div>

  <ul class="entry-list">
    {projects.map((p, index) => (
      <li class="entry">
        <a class="entry-link" href={`${base}projects/${p.key}/`}>
          <span class="entry-number">R-{String(index + 1).padStart(2, '0')}</span>
          <div class="entry-copy">
            <p class="entry-kicker">{p.data.category?.replaceAll('-', ' ') ?? 'research project'}</p>
            <h2>{p.data.title}</h2>
            {p.data.subtitle && <p class="sub">{p.data.subtitle}</p>}
            {p.data.summary && <p class="summary-line">{p.data.summary}</p>}
          </div>
          <div class="entry-side">
            {p.data.status && <span>{p.data.status}</span>}
            <span>{p.sections} section{p.sections === 1 ? '' : 's'}</span>
            <strong aria-hidden="true">↗</strong>
          </div>
        </a>
        {p.data.skills && p.data.skills.length > 0 && (
          <ul class="chips">
            {p.data.skills.slice(0, 7).map((s) => <li class="chip">{s}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
</Base>
