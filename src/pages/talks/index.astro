---
import Base from '../../layouts/Base.astro';
import TalkCard from '../../components/TalkCard.astro';
import { getCollection } from 'astro:content';

const talks = (await getCollection('talks')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || b.data.last_updated.getTime() - a.data.last_updated.getTime(),
);
---

<Base
  title="Talk Notes | Adarsh Sarda"
  description="Structured learning notes from talks and papers on AI security, red teaming, backdoors, RAG, agents, and model evaluation."
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Index 04</span> / Connected learning artifacts</p>
    <h1>Talk Notes</h1>
    <p>
      Talks and papers mapped into threat models, defensive lessons, personal takeaways,
      and links to the rest of my AI-security field notes.
    </p>
  </div>

  <div class="talk-card-grid">
    {talks.map((talk, index) => <TalkCard entry={talk} index={index} />)}
  </div>
</Base>

<style>
  .talk-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 820px) {
    .talk-card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
