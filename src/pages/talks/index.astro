---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const talks = (await getCollection('talks')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || b.data.last_updated.getTime() - a.data.last_updated.getTime(),
);
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Base
  title="Talks | Adarsh Sarda"
  description="Conference presentations and paper explainers on AI security, adversarial machine learning, and trustworthy AI."
  wide
>
  <div class="page-head">
    <p class="eyebrow"><span>Index 04</span> / Presentations and paper reviews</p>
    <h1>Talks</h1>
    <p>
      Presentations that translate current AI-security research into threat models,
      experimental results, defensive lessons, and open questions.
    </p>
  </div>

  <ul class="entry-list">
    {talks.map((talk, index) => (
      <li class="entry">
        <a class="entry-link" href={`${base}talks/${talk.id}/`}>
          <span class="entry-number">T-{String(index + 1).padStart(2, '0')}</span>
          <div class="entry-copy">
            <p class="entry-kicker">
              {talk.data.track ? `${talk.data.track} / ` : ''}{talk.data.format}
            </p>
            <h2>{talk.data.title}</h2>
            <p class="summary-line">{talk.data.description}</p>
          </div>
          <div class="entry-side">
            <time datetime={talk.data.last_updated.toISOString()}>
              Updated {dateFmt.format(talk.data.last_updated)}
            </time>
            <strong aria-hidden="true">↗</strong>
          </div>
        </a>
        {talk.data.tags && talk.data.tags.length > 0 && (
          <ul class="chips">
            {talk.data.tags.map((tag) => <li class="chip">{tag}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
</Base>
