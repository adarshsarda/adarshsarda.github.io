---
import Base from '../../layouts/Base.astro';
import ArtifactLinks from '../../components/ArtifactLinks.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'talks'> };
const { Content, headings } = await render(entry);
const data = entry.data;
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const dateFmt = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<Base
  title={`${data.title} | Talk`}
  description={data.description}
  type="article"
  structuredData={{
    '@type': 'PresentationDigitalDocument',
    '@id': `${Astro.url}#talk`,
    name: data.title,
    description: data.description,
    url: Astro.url.toString(),
    dateModified: data.last_updated.toISOString(),
    creator: { '@id': `${Astro.site ?? Astro.url.origin}#person` },
    isBasedOn: data.paper_url,
    keywords: data.tags?.join(', '),
  }}
  wide
>
  <p class="crumb"><a href={`${base}talks/`}>Index 04 / Talks</a></p>

  <header class="article-head">
    <div class="article-label">
      <span>{data.format} / T-{String(data.order ?? 1).padStart(2, '0')}</span>
      <span>Updated {dateFmt.format(data.last_updated)}</span>
    </div>
    <h1>{data.title}</h1>
    <p class="subtitle">{data.description}</p>

    <dl class="meta-table">
      <dt>Speaker</dt><dd>{data.speaker}</dd>
      <dt>Event</dt><dd>{data.event}</dd>
      <dt>Updated</dt>
      <dd><time datetime={data.last_updated.toISOString()}>{dateFmt.format(data.last_updated)}</time></dd>
      {data.paper_title && (<><dt>Paper</dt><dd>{data.paper_title}</dd></>)}
      {data.paper_authors && (<><dt>Authors</dt><dd>{data.paper_authors.join(', ')}</dd></>)}
      {data.paper_venue && (<><dt>Venue</dt><dd>{data.paper_venue}</dd></>)}
    </dl>

    <div class="talk-scope">
      <strong>Attribution:</strong> This is my explanation and presentation of another
      research team’s paper, not my original research.
    </div>

    {data.tags && data.tags.length > 0 && (
      <ul class="chips article-tags">
        {data.tags.map((tag) => <li class="chip">{tag}</li>)}
      </ul>
    )}

    <div class="artifact-links">
      {data.paper_url && (
        <a href={data.paper_url} target="_blank" rel="noopener noreferrer">
          <span>paper</span>
          Read the original paper <b aria-hidden="true">↗</b>
        </a>
      )}
    </div>
    <ArtifactLinks artifacts={data.artifacts} />
  </header>

  <div class="with-toc">
    <article class="prose">
      <Content />
    </article>

    {toc.length > 0 && (
      <aside class="toc" aria-label="On this page">
        <p class="toc-label">On this page</p>
        <ul>
          {toc.map((heading) => (
            <li class={`depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</Base>

<style>
  .talk-scope {
    max-width: 820px;
    margin-top: 30px;
    padding: 14px 18px;
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--sky) 45%, transparent);
    border-left: 3px solid var(--signal);
    font-size: 0.9rem;
  }
</style>
