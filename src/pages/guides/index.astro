---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guides = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Field Notes | Adarsh Sarda" description="Practical field notes on AI security and red teaming." wide>
  <div class="page-head">
    <p class="eyebrow"><span>Index 03</span> / Methods and checklists</p>
    <h1>Field notes</h1>
    <p>Long-form methodology and practitioner notes for assessing, breaking, and hardening AI systems.</p>
  </div>

  <ul class="entry-list">
    {guides.map((g, index) => (
      <li class="entry">
        <a class="entry-link" href={`${base}guides/${g.id}/`}>
          <span class="entry-number">N-{String(index + 1).padStart(2, '0')}</span>
          <div class="entry-copy">
            <p class="entry-kicker">Practitioner guide</p>
            <h2>{g.data.title}</h2>
            {g.data.description && <p class="summary-line">{g.data.description}</p>}
          </div>
          <div class="entry-side">
            {g.data.last_updated && (
              <time datetime={g.data.last_updated.toISOString()}>
                {dateFmt.format(g.data.last_updated)}
              </time>
            )}
            <strong aria-hidden="true">↗</strong>
          </div>
        </a>
        {g.data.tags && g.data.tags.length > 0 && (
          <ul class="chips">
            {g.data.tags.map((t) => <li class="chip">{t}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
</Base>
