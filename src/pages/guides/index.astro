---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guides = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);
---

<Base title="Field Notes | Adarsh Sarda" description="Practical field notes on AI security and red teaming." wide>
  <div class="page-head">
    <p class="eyebrow"><span>Index 03</span> / Methods and checklists</p>
    <h1>Field Notes</h1>
    <p>Long-form methodology and practitioner notes for assessing, breaking, and hardening AI systems.</p>
  </div>

  <div class="note-card-list">
    {guides.map((guide, index) => (
      <a class="note-card" href={`${base}guides/${guide.id}/`}>
        <div class="note-card-top">
          <p class="note-index">N-{String(index + 1).padStart(2, '0')}</p>
          <p class="entry-kicker">Practitioner field note</p>
        </div>
        <h2>{guide.data.title}</h2>
        {guide.data.description && <p class="note-card-desc">{guide.data.description}</p>}
        <div class="note-card-foot">
          {guide.data.tags && guide.data.tags.length > 0 && (
            <ul class="chips">
              {guide.data.tags.slice(0, 5).map((t) => <li class="chip">{t}</li>)}
            </ul>
          )}
          <span class="note-card-cta">Read the note <span aria-hidden="true">→</span></span>
        </div>
      </a>
    ))}
  </div>
</Base>
