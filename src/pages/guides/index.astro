---
import Base from '../../layouts/Base.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const guides = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);
---

<Base title="Field Notes | Adarsh Sarda" description="Practical field notes on AI security and red teaming." wide>
  <div class="page-head">
    <p class="eyebrow"><span>Notes</span> / Methods and checklists</p>
    <h1>Field Notes</h1>
    <p>Long-form methodology and practitioner notes for assessing, breaking, and hardening AI systems.</p>
  </div>

  <div class="note-card-list">
    {guides.map((guide, index) => (
      <NoteCard
        href={`${base}guides/${guide.id}/`}
        index={index}
        prefix="N"
        kicker="Practitioner field note"
        title={guide.data.title}
        description={guide.data.description}
        tags={guide.data.tags}
        cta="Read the note"
      />
    ))}
  </div>
</Base>
