---
import Base from '../layouts/Base.astro';
import '../styles/cv.css';

const base = import.meta.env.BASE_URL;
const cvVersion = '20260619';
---

<Base
  title="CV | Adarsh Sarda"
  description="English CV for Adarsh Sarda, AI security researcher and M.Sc. Artificial Intelligence student."
  alternatePath="/de/cv/"
  wide
>
  <div class="page-head cv-head">
    <p class="eyebrow"><span>Profile 05</span> / CV</p>
    <h1>CV</h1>
    <p>
      The English CV is formatted for international applications. Preview the
      document here, then open or download the full PDF.
    </p>
  </div>

  <div class="cv-grid cv-grid-single">
    <section class="cv-card-copy cv-card-copy-en" lang="en" aria-labelledby="english-cv-title">
      <div>
        <p class="cv-index">CV-01 / EN</p>
        <h2 id="english-cv-title">English CV</h2>
        <p>AI security, research experience, education, and selected technical work.</p>
      </div>
      <div class="cv-actions">
        <a
          class="text-link"
          href={`${base}cv/adarsh-sarda-cv-english.pdf?v=${cvVersion}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          Open PDF <span aria-hidden="true">↗</span>
        </a>
        <a
          class="text-link quiet"
          href={`${base}cv/adarsh-sarda-cv-english.pdf?v=${cvVersion}`}
          download
        >
          Download <span aria-hidden="true">↓</span>
        </a>
        <a class="text-link quiet" href={`${base}de/cv/`}>
          German Lebenslauf <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <a
      class="cv-preview cv-preview-en"
      href={`${base}cv/adarsh-sarda-cv-english.pdf?v=${cvVersion}`}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Open the English CV as a PDF"
    >
      <img
        src={`${base}images/cv/english-preview.png`}
        alt="Preview of Adarsh Sarda's English CV"
        width="982"
        height="1389"
        loading="eager"
      />
    </a>

    <section class="cv-note">
      <p class="profile-kicker">Application note</p>
      <p>
        Use this version for international roles. A German-language Lebenslauf
        is available in the German version of the site.
      </p>
    </section>
  </div>
</Base>
