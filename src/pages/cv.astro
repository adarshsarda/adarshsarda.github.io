---
import Base from '../layouts/Base.astro';
import '../styles/cv.css';

const base = import.meta.env.BASE_URL;
---

<Base
  title="CV | Adarsh Sarda"
  description="English and German CVs for Adarsh Sarda, AI security researcher and M.Sc. Artificial Intelligence student."
  wide
>
  <div class="page-head cv-head">
    <p class="eyebrow"><span>Profile 02</span> / CV and Lebenslauf</p>
    <h1>CV</h1>
    <p>
      Two concise versions of the same profile, formatted for international and
      German applications. Preview either document here, then open or download
      the full PDF.
    </p>
  </div>

  <div class="cv-grid">
    <article class="cv-card" lang="en">
      <div class="cv-card-copy">
        <div>
          <p class="cv-index">CV-01 / EN</p>
          <h2>English CV</h2>
          <p>AI security, research experience, education, and selected technical work.</p>
        </div>
        <div class="cv-actions">
          <a
            class="text-link"
            href={`${base}cv/adarsh-sarda-cv-english.pdf`}
            target="_blank"
            rel="noopener noreferrer"
          >
            Open PDF <span aria-hidden="true">↗</span>
          </a>
          <a
            class="text-link quiet"
            href={`${base}cv/adarsh-sarda-cv-english.pdf`}
            download
          >
            Download <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
      <a
        class="cv-preview"
        href={`${base}cv/adarsh-sarda-cv-english.pdf`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Open the English CV as a PDF"
      >
        <img
          src={`${base}images/cv/english-preview.png`}
          alt="Preview of Adarsh Sarda's English CV"
          width="982"
          height="1389"
          loading="eager"
        />
      </a>
    </article>

    <article class="cv-card" lang="de">
      <div class="cv-card-copy">
        <div>
          <p class="cv-index">CV-02 / DE</p>
          <h2>Deutscher Lebenslauf</h2>
          <p>KI-Sicherheit, Berufserfahrung, Bildungsweg und ausgewählte Forschungsarbeit.</p>
        </div>
        <div class="cv-actions">
          <a
            class="text-link"
            href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf`}
            target="_blank"
            rel="noopener noreferrer"
          >
            PDF öffnen <span aria-hidden="true">↗</span>
          </a>
          <a
            class="text-link quiet"
            href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf`}
            download
          >
            Herunterladen <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>
      <a
        class="cv-preview"
        href={`${base}cv/adarsh-sarda-lebenslauf-deutsch.pdf`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Deutschen Lebenslauf als PDF öffnen"
      >
        <img
          src={`${base}images/cv/german-preview.png`}
          alt="Vorschau des deutschen Lebenslaufs von Adarsh Sarda"
          width="982"
          height="1389"
          loading="lazy"
        />
      </a>
    </article>
  </div>

  <section class="cv-note">
    <p class="profile-kicker">Application note</p>
    <p>
      Both documents contain the same core experience. Use the English version
      for international roles and the German version for applications written
      in German.
    </p>
  </section>
</Base>
