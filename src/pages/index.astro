---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const projectEntries = await getCollection('projects');
const guideEntries = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);

// Projects are grouped by directory, so count distinct projects, not files.
const projectCount = new Set(projectEntries.map((e) => e.id.split('/')[0])).size;
const guideCount = guideEntries.length;
const featuredProject = projectEntries.find((e) => e.data.type === 'project') ?? projectEntries[0];
const featuredProjectSlug = featuredProject?.id.split('/')[0];
---

<Base
  title="Adarsh Sarda"
  description="Research and field notes on AI security, LLM red teaming, and adversarial machine learning."
  wide
>
  <section class="home-hero">
    <div class="hero-main">
      <p class="hero-name">Adarsh Sarda</p>
      <p class="eyebrow"><span>Research & field notes</span> / AI security</p>
      <h1>I build and break <em>AI systems.</em></h1>
      <p class="hero-deck">
        I work on adversarial machine learning, LLM red teaming, and experimental
        security research. Each write-up records the method, evidence, failed
        attempts, and limits of the result.
      </p>
      <div class="hero-actions">
        <a class="text-link" href={`${base}projects/`}>Read the research <span aria-hidden="true">↗</span></a>
        <a class="text-link quiet" href={`${base}guides/`}>Browse field notes <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <figure class="hero-portrait">
      <div class="portrait-frame">
        <img
          src={`${base}images/portrait.jpeg`}
          alt="Portrait outdoors beside a river"
          width="900"
          height="1600"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="portrait-note">
        <p class="note-label">Current inquiry / 2026</p>
        <p>Can a multi-turn model learn a hidden rule based on the <strong>order of meanings</strong> rather than a keyword?</p>
      </div>
    </figure>
  </section>

  {featuredProject && featuredProjectSlug && (
    <section class="home-section">
      <header class="section-heading">
        <p><span>01</span> Selected research</p>
        <p>{projectCount.toString().padStart(2, '0')} case {projectCount === 1 ? 'file' : 'files'}</p>
      </header>
      <a class="feature-work" href={`${base}projects/${featuredProjectSlug}/`}>
        <div class="feature-index">R-01</div>
        <div class="feature-copy">
          <p class="work-type">{featuredProject.data.category?.replace('-', ' ') ?? 'Research project'}</p>
          <h2>{featuredProject.data.title}</h2>
          {featuredProject.data.subtitle && <p>{featuredProject.data.subtitle}</p>}
        </div>
        <div class="feature-status">
          <span>{featuredProject.data.status ?? 'documented'}</span>
          <strong aria-hidden="true">↗</strong>
        </div>
      </a>
    </section>
  )}

  {guideEntries.length > 0 && (
    <section class="home-section notes-section">
      <header class="section-heading">
        <p><span>02</span> Field notes</p>
        <p>{guideCount.toString().padStart(2, '0')} long-form {guideCount === 1 ? 'guide' : 'guides'}</p>
      </header>
      {guideEntries.map((guide, index) => (
        <a class="note-row" href={`${base}guides/${guide.id}/`}>
          <p class="note-index">N-{String(index + 1).padStart(2, '0')}</p>
          <h2>{guide.data.title}</h2>
          <p>{guide.data.description}</p>
          <span aria-hidden="true">→</span>
        </a>
      ))}
    </section>
  )}
</Base>
