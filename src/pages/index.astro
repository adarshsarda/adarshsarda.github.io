---
import Base from '../layouts/Base.astro';
import TalkCard from '../components/TalkCard.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const projectEntries = await getCollection('projects');
const guideEntries = (await getCollection('guides')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || (b.data.last_updated?.getTime() ?? 0) - (a.data.last_updated?.getTime() ?? 0),
);
const talkEntries = (await getCollection('talks')).sort(
  (a, b) =>
    (a.data.order ?? Number.MAX_SAFE_INTEGER) - (b.data.order ?? Number.MAX_SAFE_INTEGER)
    || b.data.last_updated.getTime() - a.data.last_updated.getTime(),
);

const projects = projectEntries
  .filter((entry) => entry.data.type === 'project')
  .map((entry) => ({ key: entry.data.slug, data: entry.data }))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projectCount = projects.length;
const guideCount = guideEntries.length;
const talkCount = talkEntries.length;
---

<Base
  title="Adarsh Sarda | AI Security Researcher"
  description="Research and field notes on AI security, LLM red teaming, and adversarial machine learning."
  wide
>
  <section class="home-hero">
    <div class="hero-main">
      <p class="hero-name">Adarsh Sarda</p>
      <p class="eyebrow"><span>Research & field notes</span> / AI security</p>
      <h1>I build and break <em>AI systems.</em></h1>
      <p class="hero-deck">
        I work on adversarial machine learning, LLM red teaming, and experimental
        security research. Each write-up records the method, evidence, failed
        attempts, and limits of the result.
      </p>
      <div class="hero-actions">
        <a class="text-link" href={`${base}projects/`}>Read the research <span aria-hidden="true">↗</span></a>
        <a class="text-link quiet" href={`${base}about/`}>About my work <span aria-hidden="true">→</span></a>
        <a class="text-link quiet" href={`${base}cv/`}>
          CV / Lebenslauf <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <figure class="hero-portrait">
      <div class="portrait-frame">
        <img
          src={`${base}images/portrait.jpeg`}
          alt="Portrait outdoors beside a river"
          width="900"
          height="1600"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="portrait-note">
        <p class="note-label">Current inquiry / 2026</p>
        <p>Can a multi-turn model learn a hidden rule based on the <strong>order of meanings</strong> rather than a keyword?</p>
      </div>
    </figure>
  </section>

  {projects.length > 0 && (
    <section class="home-section">
      <header class="section-heading">
        <p><span>01</span> Selected research</p>
        <p>{projectCount.toString().padStart(2, '0')} case {projectCount === 1 ? 'file' : 'files'}</p>
      </header>
      <div class="project-card-list">
        {projects.map((project, index) => (
          <a class="project-card" href={`${base}projects/${project.key}/`}>
            <div class="project-card-main">
              <div class="project-card-head">
                <span class="project-index">R-{String(index + 1).padStart(2, '0')}</span>
                <p class="entry-kicker">{project.data.category?.replaceAll('-', ' ') ?? 'research project'}</p>
              </div>
              <h2>{project.data.title}</h2>
              {project.data.subtitle && <p class="project-card-sub">{project.data.subtitle}</p>}
              {project.data.summary && <p class="project-card-summary">{project.data.summary}</p>}
              {project.data.skills && project.data.skills.length > 0 && (
                <ul class="chips">
                  {project.data.skills.slice(0, 6).map((s) => <li class="chip">{s}</li>)}
                </ul>
              )}
            </div>
            <div class="project-card-rail">
              <div class="project-rail-item">
                <p class="rail-label">Status</p>
                <p class="rail-value">{project.data.status ?? 'documented'}</p>
              </div>
              {project.data.domains && project.data.domains.length > 0 && (
                <div class="project-rail-item">
                  <p class="rail-label">Focus</p>
                  <p class="rail-value">{project.data.domains.join(' · ')}</p>
                </div>
              )}
              <span class="project-card-cta">Open case file <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {guideEntries.length > 0 && (
    <section class="home-section notes-section">
      <header class="section-heading">
        <p><span>02</span> Field Notes</p>
        <p>{guideCount.toString().padStart(2, '0')} long-form {guideCount === 1 ? 'guide' : 'guides'}</p>
      </header>
      <div class="note-card-list">
        {guideEntries.map((guide, index) => (
          <a class="note-card" href={`${base}guides/${guide.id}/`}>
            <div class="note-card-top">
              <p class="note-index">N-{String(index + 1).padStart(2, '0')}</p>
              <p class="entry-kicker">Practitioner field note</p>
            </div>
            <h2>{guide.data.title}</h2>
            {guide.data.description && <p class="note-card-desc">{guide.data.description}</p>}
            <div class="note-card-foot">
              {guide.data.tags && guide.data.tags.length > 0 && (
                <ul class="chips">
                  {guide.data.tags.slice(0, 5).map((t) => <li class="chip">{t}</li>)}
                </ul>
              )}
              <span class="note-card-cta">Read the note <span aria-hidden="true">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {talkEntries.length > 0 && (
    <section class="home-section talks-section" data-talk-carousel>
      <header class="section-heading">
        <p><span>03</span> Talk Notes</p>
        <p>{talkCount.toString().padStart(2, '0')} {talkCount === 1 ? 'presentation' : 'presentations'}</p>
      </header>

      <div class="talk-carousel-shell">
        <button
          class="talk-carousel-arrow talk-carousel-arrow-prev"
          type="button"
          aria-label="Show previous talk note"
          aria-controls="home-talk-carousel"
          data-talk-prev
          disabled
        >
          <span aria-hidden="true">←</span>
        </button>

        <ol
          class="talk-carousel-track"
          id="home-talk-carousel"
          aria-label="Talk Notes carousel"
          tabindex="0"
          data-talk-track
        >
          {talkEntries.map((talk, index) => (
            <li class="talk-carousel-slide">
              <TalkCard entry={talk} index={index} />
            </li>
          ))}
        </ol>

        <button
          class="talk-carousel-arrow talk-carousel-arrow-next"
          type="button"
          aria-label="Show next talk note"
          aria-controls="home-talk-carousel"
          data-talk-next
        >
          <span aria-hidden="true">→</span>
        </button>
      </div>

      <footer class="talk-carousel-footer">
        <p class="talk-carousel-status" aria-live="polite">
          <span data-talk-position>01-02</span>
          <span aria-hidden="true"> / </span>
          <span>{talkCount.toString().padStart(2, '0')}</span>
        </p>
        <div>
          <p>Use the arrows, swipe, or scroll horizontally.</p>
          <a class="text-link quiet" href={`${base}talks/`}>
            Open the full talk index <span aria-hidden="true">→</span>
          </a>
        </div>
      </footer>
    </section>
  )}

  <section class="home-section principles-section">
    <header class="section-heading">
      <p><span>04</span> Research principles</p>
      <p>How I evaluate evidence</p>
    </header>
    <div class="principle-grid">
      <div>
        <span>01</span>
        <h2>Measure statistically.</h2>
        <p>AI failures are probabilistic. Report rates, sample sizes, controls, and uncertainty.</p>
      </div>
      <div>
        <span>02</span>
        <h2>Report failed iterations.</h2>
        <p>A discarded shortcut can teach more about the system than a polished final score.</p>
      </div>
      <div>
        <span>03</span>
        <h2>Separate demos from evidence.</h2>
        <p>Installation, generalisation, utility, and real-world risk are different claims.</p>
      </div>
      <div>
        <span>04</span>
        <h2>Question perfect results.</h2>
        <p>Perfect scores demand stronger audits, not stronger adjectives.</p>
      </div>
    </div>
  </section>

  <section class="home-section contact-section">
    <div>
      <p class="profile-kicker">Open to collaboration</p>
      <h2>AI security, LLM evaluation, and applied machine learning.</h2>
      <p>Based in Amberg, Germany. Available immediately for Werkstudent roles at 20 hours/week, either on-site around Amberg, Regensburg, Nuremberg and nearby areas, or remote.</p>
    </div>
    <div class="contact-actions">
      <a class="text-link" href="mailto:adarshsarda29@gmail.com">Email <span aria-hidden="true">→</span></a>
      <a class="text-link quiet" href="https://www.linkedin.com/in/adarshsarda" target="_blank" rel="noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
      <a class="text-link quiet" href="https://github.com/adarshsarda/" target="_blank" rel="noreferrer">GitHub <span aria-hidden="true">↗</span></a>
    </div>
  </section>
</Base>

<script>
  const carousels = document.querySelectorAll<HTMLElement>('[data-talk-carousel]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  carousels.forEach((carousel) => {
    const track = carousel.querySelector<HTMLOListElement>('[data-talk-track]');
    const previous = carousel.querySelector<HTMLButtonElement>('[data-talk-prev]');
    const next = carousel.querySelector<HTMLButtonElement>('[data-talk-next]');
    const position = carousel.querySelector<HTMLElement>('[data-talk-position]');
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.talk-carousel-slide'));

    if (!track || !previous || !next || !position || slides.length === 0) return;

    const metrics = () => {
      const firstSlide = slides[0];
      const styles = getComputedStyle(track);
      const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;
      const step = firstSlide.getBoundingClientRect().width + gap;
      const visible = Math.max(1, Math.round((track.clientWidth + gap) / step));
      return { step, visible };
    };

    const update = () => {
      const { step, visible } = metrics();
      const first = Math.min(
        slides.length,
        Math.max(1, Math.round(track.scrollLeft / step) + 1),
      );
      const last = Math.min(slides.length, first + visible - 1);
      const maxScroll = Math.max(0, track.scrollWidth - track.clientWidth);

      previous.disabled = track.scrollLeft <= 2;
      next.disabled = track.scrollLeft >= maxScroll - 2;
      position.textContent = first === last
        ? String(first).padStart(2, '0')
        : `${String(first).padStart(2, '0')}-${String(last).padStart(2, '0')}`;
    };

    const move = (direction: number) => {
      const { step } = metrics();
      track.scrollBy({
        left: direction * step,
        behavior: reduceMotion.matches ? 'auto' : 'smooth',
      });
    };

    previous.addEventListener('click', () => move(-1));
    next.addEventListener('click', () => move(1));
    track.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        move(-1);
      }
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        move(1);
      }
    });

    let frame = 0;
    track.addEventListener('scroll', () => {
      cancelAnimationFrame(frame);
      frame = requestAnimationFrame(update);
    }, { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>

<style>
  .talk-carousel-shell {
    position: relative;
    margin-top: 18px;
  }

  .talk-carousel-track {
    margin: 0;
    padding: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 18px) / 2);
    gap: 18px;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-behavior: smooth;
    scroll-snap-type: inline mandatory;
    scrollbar-width: none;
    list-style: none;
  }

  .talk-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .talk-carousel-track:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 5px;
  }

  .talk-carousel-slide {
    min-width: 0;
    display: grid;
    scroll-snap-align: start;
  }

  .talk-carousel-arrow {
    position: absolute;
    z-index: 3;
    top: 50%;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    color: var(--paper-raised);
    background: var(--signal-dark);
    border: 1px solid var(--paper-raised);
    border-radius: 50%;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--ink) 24%, transparent);
    font-family: var(--font-body);
    font-size: 1.4rem;
    cursor: pointer;
    transform: translateY(-50%);
    transition: background-color 160ms ease, transform 160ms ease, opacity 160ms ease;
  }

  .talk-carousel-arrow:hover:not(:disabled) {
    background: var(--signal);
    transform: translateY(-50%) scale(1.06);
  }

  .talk-carousel-arrow:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 4px;
  }

  .talk-carousel-arrow:disabled {
    opacity: 0.28;
    cursor: default;
  }

  .talk-carousel-arrow-prev {
    left: -24px;
  }

  .talk-carousel-arrow-next {
    right: -24px;
  }

  .talk-carousel-footer {
    padding-top: 18px;
    display: flex;
    justify-content: space-between;
    gap: 30px;
    align-items: flex-end;
  }

  .talk-carousel-footer > div {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
    gap: 14px 28px;
  }

  .talk-carousel-footer p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.78rem;
  }

  .talk-carousel-status {
    flex: none;
    color: var(--signal-dark) !important;
    font-family: var(--font-mono);
    font-size: 0.72rem !important;
    font-weight: 750;
    letter-spacing: 0.06em;
  }

  @media (max-width: 820px) {
    .talk-carousel-track {
      grid-auto-columns: 100%;
    }

    .talk-carousel-arrow-prev {
      left: -12px;
    }

    .talk-carousel-arrow-next {
      right: -12px;
    }
  }

  @media (max-width: 600px) {
    .talk-carousel-shell {
      padding-bottom: 62px;
    }

    .talk-carousel-arrow {
      top: auto;
      bottom: 0;
      transform: none;
    }

    .talk-carousel-arrow:hover:not(:disabled) {
      transform: scale(1.06);
    }

    .talk-carousel-arrow-prev {
      left: 0;
    }

    .talk-carousel-arrow-next {
      right: 0;
    }

    .talk-carousel-footer {
      padding-top: 14px;
      align-items: flex-start;
    }

    .talk-carousel-footer > div {
      justify-content: flex-end;
    }

    .talk-carousel-footer > div > p {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .talk-carousel-track {
      scroll-behavior: auto;
    }

    .talk-carousel-arrow {
      transition: none;
    }
  }
</style>
